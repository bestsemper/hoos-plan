{
  "manifest_version": 3,
  "name": "Plan Your Future - TCF Overlay",
  "version": "1.0",
  "description": "Overlays CourseForum data onto UVA course planning sites.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://thecourseforum.com/api/*",
    "*://sisuva.admin.virginia.edu/*",
    "*://*.virginia.edu/*",
    "*://*.stellic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://sisuva.admin.virginia.edu/*",
        "*://*.virginia.edu/*",
        "*://*.stellic.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
